    @Override
    public void start(Stage primaryStage) {
        this.window = primaryStage;
        
        // Setup initial menu scene
        createMainMenu();

        window.setTitle("Jackaroo: A New Game Spin");
        window.setScene(menuScene);
        window.setResizable(false);
        window.show();
