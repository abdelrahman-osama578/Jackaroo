    private void updateLog(String message) {
        logArea.appendText("> " + message + "\n\n");
    }

    // ==========================================
    // DRAWING THE BOARD
    // ==========================================

    private void updateUI() {
        boardPane.getChildren().removeIf(node -> node instanceof Circle || node.getId() != null);
        handPane.getChildren().clear();

        drawTrackAndMarbles();
        drawPlayerInfoAndCPUHands();
        drawHumanHand();
        updateFirepit();

        turnLabel.setText("Current Turn: " + game.getActivePlayerColour());
        nextPlayerLabel.setText("Next Player: " + game.getNextPlayerColour());
    }

    private void setControlsEnabled(boolean enabled) {
        handPane.setDisable(!enabled);
        controlsPane.setDisable(!enabled);
    }

    private void drawTrackAndMarbles() {
        ArrayList<Cell> track = game.getBoard().getTrack();
        for (int i = 0; i < track.size(); i++) {
            Cell cell = track.get(i);
            double[] coords = getCrossCoordinates(i);
            
            Rectangle rect = new Rectangle(coords[0], coords[1], CELL_SIZE, CELL_SIZE);
            rect.setStroke(Color.BLACK);
            rect.setFill(cell.getCellType() == CellType.BASE ? Color.LIGHTBLUE : 
                         cell.getCellType() == CellType.ENTRY ? Color.LIGHTGREEN : 
                         cell.isTrap() ? Color.DARKGRAY : Color.WHITE);
            
            rect.setId("trackCell");
            boardPane.getChildren().add(rect);

            if (cell.getMarble() != null) drawMarble(cell.getMarble(), coords[0], coords[1]);
        }

        for (SafeZone zone : game.getBoard().getSafeZones()) {
            int idx = 0;
            for(Cell cell : zone.getCells()) {
                double[] coords = getSafeZoneCoords(zone.getColour(), idx++);
                Rectangle sr = new Rectangle(coords[0], coords[1], CELL_SIZE, CELL_SIZE);
                sr.setFill(getPaint(zone.getColour()).deriveColor(1,1,1,0.4));
                sr.setId("safeCell");
                boardPane.getChildren().add(sr);
                
                if(cell.getMarble() != null) drawMarble(cell.getMarble(), coords[0], coords[1]);
            }
        }

        for (Player p : game.getPlayers()) {
            double[] homeBase = getHomeZoneCoords(p.getColour());
            int count = 0;
            for (Marble m : p.getMarbles()) {
                drawMarble(m, homeBase[0] + (count % 2) * 25, homeBase[1] + (count / 2) * 25);
                count++;
            }
        }
    }

    private void drawMarble(Marble marble, double x, double y) {
        Circle circle = new Circle(x + CELL_SIZE / 2.0, y + CELL_SIZE / 2.0, CELL_SIZE / 2.2);
        circle.setFill(getPaint(marble.getColour()));
        circle.setStroke(Color.BLACK);

        circle.setOnMouseClicked(e -> {
            if(controlsPane.isDisabled()) return; 
            try {
                game.selectMarble(marble);
                guiSelectedMarbles.add(marble); 
                circle.setStroke(Color.GOLD);
                circle.setStrokeWidth(3);
            } catch (GameException ex) {
                showAlert(JOptionPane.WARNING_MESSAGE, "Invalid Selection", ex.getMessage());
            }
        });
        boardPane.getChildren().add(circle);
    }

    private void drawPlayerInfoAndCPUHands() {
        for (Player p : game.getPlayers()) {
            double[] coords = getHomeZoneCoords(p.getColour());
            Label nameLabel = new Label(p.getName() + "\nCards: " + p.getHand().size());
            nameLabel.setFont(Font.font("Arial", FontWeight.BOLD, 14));
            nameLabel.setTextFill(getPaint(p.getColour()));
            nameLabel.setId("playerLabel");
            AnchorPane.setTopAnchor(nameLabel, coords[1] - 40);
            AnchorPane.setLeftAnchor(nameLabel, coords[0]);
            boardPane.getChildren().add(nameLabel);
        }
    }

    private void drawHumanHand() {
        Player human = game.getPlayers().get(0);
        for (Card card : human.getHand()) {
            Button cardBtn = new Button();
            if (card instanceof Standard) {
                Standard std = (Standard) card;
                cardBtn.setText(std.getName() + "\n" + std.getSuit());
            } else {
                cardBtn.setText(card.getName() + "\nWild");
            }
            cardBtn.setPrefSize(75, 110);
            cardBtn.setOnAction(e -> {
                try {
                    game.selectCard(card);
                    handPane.getChildren().forEach(n -> n.setStyle(""));
                    cardBtn.setStyle("-fx-border-color: gold; -fx-border-width: 3;");
                } catch (GameException ex) {
                    showAlert(JOptionPane.WARNING_MESSAGE, "Selection Error", ex.getMessage());
                }
            });
            handPane.getChildren().add(cardBtn);
        }
    }

    private void updateFirepit() {
        if (firepitPane.getChildren().size() > 1) {
            firepitPane.getChildren().remove(1, firepitPane.getChildren().size());
        }
        ArrayList<Card> fp = game.getFirePit();
        Card topCard = null;
        for (int i = fp.size() - 1; i >= 0; i--) {
            if (fp.get(i) != null) {
                topCard = fp.get(i);
                break;
            }
        }
        if (topCard != null) {
            Label cardLabel = new Label(topCard.getName());
            cardLabel.setStyle("-fx-background-color: white; -fx-padding: 20; -fx-border-color: black;");
            firepitPane.getChildren().add(cardLabel);
        }
    }

    // ==========================================
    // ENGINE & TURN LOGIC
    // ==========================================

    private void handleHumanTurn() {
        Player human = game.getPlayers().get(0);
        Card selected = human.getSelectedCard();

        if (selected == null) {
            showAlert(JOptionPane.WARNING_MESSAGE, "No Card Selected", "Please select a card to play.");
            return;
        }

        if (selected instanceof Seven && guiSelectedMarbles.size() == 2) {
            Integer[] options = {1, 2, 3, 4, 5, 6};
            Integer result = (Integer) JOptionPane.showInputDialog(null, "Split Moves:", "Seven", JOptionPane.QUESTION_MESSAGE, null, options, options[2]);
            if (result != null) {
                try { game.editSplitDistance(result); } 
                catch (SplitOutOfRangeException ex) { showAlert(JOptionPane.ERROR_MESSAGE, "Invalid Split", ex.getMessage()); return; }
            } else return; 
        }

        try {
            int preHomeSize = human.getMarbles().size();
            String cardName = selected.getName();
            
            game.playPlayerTurn();
            game.endPlayerTurn();
            
            updateLog(human.getName() + " played: " + cardName);
            guiSelectedMarbles.clear();
            updateUI();

            if (human.getMarbles().size() > preHomeSize && !(selected.getName().contains("Burner"))) {
                updateLog("TRAP TRIGGERED! " + human.getName() + " lost a marble.");
                showAlert(JOptionPane.INFORMATION_MESSAGE, "Trap Triggered!", "A marble fell into a trap cell and was returned home!");
            }

            Colour winner = game.checkWin();
            if (winner != null) {
                updateLog("GAME OVER. " + winner + " wins!");
                showAlert(JOptionPane.INFORMATION_MESSAGE, "Game Over", winner + " has won the game!");
                return;
            }

            executeCPUTurns();

        } catch (GameException e) {
            showAlert(JOptionPane.WARNING_MESSAGE, "Invalid Move", e.getMessage());
            game.deselectAll();
            guiSelectedMarbles.clear();
            updateUI();
        }
    }
    
    private void handleDiscardTurn() {
        Player human = game.getPlayers().get(0);
        if (human.getSelectedCard() == null) {
            showAlert(JOptionPane.WARNING_MESSAGE, "No Card", "Select a card to discard.");
            return;
        }
        updateLog(human.getName() + " discarded " + human.getSelectedCard().getName() + " and passed.");
        try { game.endPlayerTurn(); } catch (Exception ignored) {}
        guiSelectedMarbles.clear();
        updateUI();
        executeCPUTurns();
    }

    private void executeCPUTurns() {
        if (cpuTimeline != null && cpuTimeline.getStatus() == Timeline.Status.RUNNING) return;

        setControlsEnabled(false); 

        cpuTimeline = new Timeline();
        KeyFrame kf = new KeyFrame(Duration.seconds(1.2), e -> {
            Player human = game.getPlayers().get(0);

            if (game.getActivePlayerColour() == human.getColour()) {
                if (!game.canPlayTurn()) {
                    updateLog(human.getName() + "'s turn was skipped (No Cards).");
                    try { game.endPlayerTurn(); } catch (Exception ignored) {}
                    guiSelectedMarbles.clear();
                    updateUI();
                } else {
                    setControlsEnabled(true);
                    cpuTimeline.stop();
                }
            } else {
                Player active = null;
                for (Player p : game.getPlayers()) if (p.getColour() == game.getActivePlayerColour()) active = p;
                
                if (active instanceof CPU) {
                    if (game.canPlayTurn()) {
                        try { active.play(); } catch (Exception ignored) {}
                    }
                    try { game.endPlayerTurn(); } catch (Exception ignored) {}
                    updateUI();

                    // Read firepit to log CPU's action
                    ArrayList<Card> fp = game.getFirePit();
                    String actionCard = "Skipped/Unknown";
                    for (int i = fp.size() - 1; i >= 0; i--) {
                        if (fp.get(i) != null) { actionCard = fp.get(i).getName(); break; }
                    }
                    updateLog(active.getName() + " finished turn. (Used: " + actionCard + ")");

                    Colour winner = game.checkWin();
                    if (winner != null) {
                        updateLog("GAME OVER. " + winner + " wins!");
                        showAlert(JOptionPane.INFORMATION_MESSAGE, "Game Over", winner + " has won the game!");
                        cpuTimeline.stop();
                    }
                }
            }
        });
        
        cpuTimeline.getKeyFrames().add(kf);
        cpuTimeline.setCycleCount(Timeline.INDEFINITE);
        cpuTimeline.play();
    }

    // --- Mathematical Layout Helpers ---
    private double[] getCrossCoordinates(int index) {
        int side = index / 25;
        int pos = index % 25;
        double x = 250, y = 100;
        if(side == 0) { x += pos * CELL_SIZE; y = 100; }
        else if(side == 1) { x = 250 + 25 * CELL_SIZE; y = 100 + pos * CELL_SIZE; }
        else if(side == 2) { x = 250 + (25 - pos) * CELL_SIZE; y = 100 + 25 * CELL_SIZE; }
        else if(side == 3) { x = 250; y = 100 + (25 - pos) * CELL_SIZE; }
        return new double[]{x, y};
    }

    private double[] getSafeZoneCoords(Colour c, int idx) {
        double[] base = getCrossCoordinates(getEngineBaseOffset(c));
        return new double[]{base[0] + 30, base[1] + 30 + (idx * CELL_SIZE)}; 
    }

    private double[] getHomeZoneCoords(Colour c) {
        switch(c) {
            case RED: return new double[]{220, 120};
            case BLUE: return new double[]{780, 120};
            case GREEN: return new double[]{780, 680};
            case YELLOW: return new double[]{220, 680};
            default: return new double[]{0,0};
        }
    }

    private int getEngineBaseOffset(Colour c) {
        for(int i = 0; i < game.getBoard().getSafeZones().size(); i++) {
            if(game.getBoard().getSafeZones().get(i).getColour() == c) return i * 25;
        }
        return 0;
    }

    private Color getPaint(Colour c) {
        switch (c) {
            case RED: return Color.RED;
            case BLUE: return Color.DODGERBLUE;
            case GREEN: return Color.FORESTGREEN;
            case YELLOW: return Color.GOLD;
            default: return Color.BLACK;
        }
    }

    private void showAlert(int messageType, String title, String content) {
        JOptionPane.showMessageDialog(null, content, title, messageType);
    }

    public static void main(String[] args) {
        launch(args);
    }
