    // ==========================================
    // MENU & LOADING SCREENS
    // ==========================================

    private void createMainMenu() {
        VBox layout = new VBox(40);
        layout.setAlignment(Pos.CENTER);
        layout.setStyle("-fx-background-color: #1C2833;");

        Label title = new Label("JACKAROO");
        title.setFont(Font.font("Arial", FontWeight.EXTRA_BOLD, 80));
        title.setTextFill(Color.GOLD);

        Button startBtn = createMenuButton("Start Game", "#2ECC71");
        startBtn.setOnAction(e -> triggerLoadingScreen());

        Button rulesBtn = createMenuButton("View Rules", "#3498DB");
        rulesBtn.setOnAction(e -> showRulesScreen());

        Button exitBtn = createMenuButton("Exit", "#E74C3C");
        exitBtn.setOnAction(e -> window.close());

        layout.getChildren().addAll(title, startBtn, rulesBtn, exitBtn);
        menuScene = new Scene(layout, 1350, 950);
    }

    private Button createMenuButton(String text, String colorHex) {
        Button btn = new Button(text);
        btn.setFont(Font.font("Arial", FontWeight.BOLD, 24));
        btn.setStyle("-fx-background-color: " + colorHex + "; -fx-text-fill: white; -fx-background-radius: 15;");
        btn.setPrefSize(250, 60);
        return btn;
    }

    private void showRulesScreen() {
        VBox layout = new VBox(20);
        layout.setAlignment(Pos.CENTER);
        layout.setStyle("-fx-background-color: #1C2833;");
        layout.setPadding(new Insets(50));

        Label title = new Label("Game Rules");
        title.setFont(Font.font("Arial", FontWeight.BOLD, 40));
        title.setTextFill(Color.WHITE);

        TextArea rulesText = new TextArea();
        rulesText.setEditable(false);
        rulesText.setWrapText(true);
        rulesText.setFont(Font.font("Arial", 16));
        rulesText.setStyle("-fx-control-inner-background: #2E4053; -fx-text-fill: white;");
        rulesText.setText("1. Objective: Move all 4 marbles from Home to Safe Zone.\n\n" +
                "2. Fielding: You must play an Ace or King to field a marble to your Base Cell. Use the 'F' key as a shortcut.\n\n" +
                "3. Movement: Marbles move clockwise. A '4' card moves backward. A '5' forces you to move ANY marble.\n\n" +
                "4. Traps: 8 hidden trap cells will instantly destroy a marble.\n\n" +
                "5. Standard Turn: Select a card, select the required marbles, and click 'Play Turn'.\n\n" +
                "If you have no playable cards, click 'Discard / Skip'.");

        Button backBtn = createMenuButton("Back to Menu", "#E74C3C");
        backBtn.setOnAction(e -> window.setScene(menuScene));

        layout.getChildren().addAll(title, rulesText, backBtn);
        window.setScene(new Scene(layout, 1350, 950));
    }

    private void triggerLoadingScreen() {
        VBox layout = new VBox(30);
        layout.setAlignment(Pos.CENTER);
        layout.setStyle("-fx-background-color: #2E4053;");

        Circle loader = new Circle(40, Color.GOLD);
        
        // Pulsing Animation
        ScaleTransition st = new ScaleTransition(Duration.seconds(0.6), loader);
        st.setByX(0.5f);
        st.setByY(0.5f);
        st.setCycleCount(4); // Play for ~2.4 seconds
        st.setAutoReverse(true);

        Label loadText = new Label("Initializing Board Engine...");
        loadText.setFont(Font.font("Arial", FontWeight.BOLD, 24));
        loadText.setTextFill(Color.WHITE);

        layout.getChildren().addAll(loader, loadText);
        Scene loadScene = new Scene(layout, 1350, 950);
        window.setScene(loadScene);

        st.setOnFinished(e -> initializeGameEngine());
        st.play();
    }

    // ==========================================
    // GAME INITIALIZATION & UI SETUP
    // ==========================================

    private void initializeGameEngine() {
        String input = JOptionPane.showInputDialog(null, "Please enter your name:", "Game Setup", JOptionPane.QUESTION_MESSAGE);
        String playerName = (input != null && !input.trim().isEmpty()) ? input : "Player 1";

        try {
            game = new Game(playerName);
        } catch (IOException e) {
            showAlert(JOptionPane.ERROR_MESSAGE, "Initialization Error", "Could not load Cards.csv: " + e.getMessage());
            window.setScene(menuScene);
            return;
        }

        boardPane = new AnchorPane();
        boardPane.setStyle("-fx-background-color: #2E4053;"); 

        setupGameUIComponents();
        updateUI();

        gameScene = new Scene(boardPane, 1350, 950);

        gameScene.setOnKeyPressed(e -> {
            if (e.getCode() == KeyCode.F && !controlsPane.isDisabled()) {
                try {
                    game.fieldMarble();
                    updateLog(game.getPlayers().get(0).getName() + " shortcut fielded a marble!");
                    guiSelectedMarbles.clear();
                    updateUI();
                } catch (GameException ex) {
                    showAlert(JOptionPane.WARNING_MESSAGE, "Cannot Field Marble", ex.getMessage());
                }
            }
        });

        window.setScene(gameScene);
        updateLog("Game started! Welcome, " + playerName + ".");
    }

