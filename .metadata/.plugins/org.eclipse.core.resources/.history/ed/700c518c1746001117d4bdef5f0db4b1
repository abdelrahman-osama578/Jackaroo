    private StackPane buildCardTile(Card card) {
        StackPane pane = new StackPane();
        pane.setPrefSize(90, 135); 
        pane.setCursor(javafx.scene.Cursor.HAND);
        pane.setEffect(new DropShadow(10, Color.BLACK));

        Rectangle bg = new Rectangle(90, 135);
        bg.setFill(new LinearGradient(0, 0, 0, 1, true, CycleMethod.NO_CYCLE,
            new Stop(0, Color.web("#222226")),
            new Stop(1, Color.web("#0D0D0F"))));
        bg.setStroke(Color.web(C_TRACK_BRD, 0.5));
        bg.setStrokeWidth(1.5);
        bg.setArcWidth(8); bg.setArcHeight(8);

        String suitSymbol = "✦";
        if (card instanceof Standard) {
            switch (((Standard) card).getSuit()) {
                case HEART:   suitSymbol = "♥"; break;
                case DIAMOND: suitSymbol = "♦"; break;
                case CLUB:    suitSymbol = "♣"; break;
                case SPADE:   suitSymbol = "♠"; break;
            }
        }

        String rankStr = (card instanceof Standard) ? String.valueOf(((Standard) card).getRank()) : "★";

        Label rankL = new Label(rankStr);
        rankL.setFont(Font.font("Georgia", FontWeight.BOLD, 32));
        rankL.setTextFill(Color.web(C_TEXT_MAIN));
        StackPane.setAlignment(rankL, Pos.TOP_LEFT);
        rankL.setPadding(new Insets(5, 0, 0, 10));

        Label suitL = new Label(suitSymbol);
        suitL.setFont(Font.font("Georgia", 20));
        boolean isRed = (card instanceof Standard) &&
            (((Standard)card).getSuit() == model.card.standard.Suit.HEART ||
             ((Standard)card).getSuit() == model.card.standard.Suit.DIAMOND);
        suitL.setTextFill(isRed ? Color.web(C_CRIMSON) : Color.web(C_TEXT_DIM));
        StackPane.setAlignment(suitL, Pos.TOP_RIGHT);
        suitL.setPadding(new Insets(10, 10, 0, 0));

        Label nameL = new Label(card.getName().toUpperCase());
        nameL.setFont(trackedFont(9));
        nameL.setTextFill(Color.web(C_GOLD));
        nameL.setWrapText(true);
        nameL.setMaxWidth(80);
        nameL.setTextAlignment(TextAlignment.CENTER);
        StackPane.setAlignment(nameL, Pos.BOTTOM_CENTER);
        nameL.setPadding(new Insets(0, 0, 15, 0));

        pane.getChildren().addAll(bg, rankL, suitL, nameL);
        return pane;
    }

    private void updateFirepit() {
        firepitPane.getChildren().removeIf(n -> n instanceof Label && ((Label)n).getText().contains("\n") == false
            && !((Label)n).getText().equals("THE\nVOID"));

        ArrayList<Card> fp = game.getFirePit();
        for (int i = fp.size() - 1; i >= 0; i--) {
            if (fp.get(i) != null) {
                Card top = fp.get(i);
                String display = top.getName().toUpperCase();
                if (top instanceof Standard) display += "\n" + ((Standard)top).getSuit();

                Label lbl = new Label(display);
                lbl.setFont(trackedFont(10));
                lbl.setTextFill(Color.web(C_TEXT_MAIN));
                lbl.setTextAlignment(TextAlignment.CENTER);
                lbl.setAlignment(Pos.CENTER);
                firepitPane.getChildren().add(lbl);

                lbl.setOpacity(0);
                FadeTransition ft = new FadeTransition(Duration.millis(500), lbl);
                ft.setToValue(1); ft.play();
                break;
            }
        }
    }

