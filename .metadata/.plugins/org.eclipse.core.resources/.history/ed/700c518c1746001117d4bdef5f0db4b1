    private void triggerLoadingScreen() {
        StackPane root = new StackPane();
        Rectangle bg = new Rectangle();
        bg.widthProperty().bind(root.widthProperty());
        bg.heightProperty().bind(root.heightProperty());
        bg.setFill(Color.web(C_BG_DEEP));
        root.getChildren().add(bg);
        
        Canvas embers = buildEmberCanvas();
        embers.widthProperty().bind(root.widthProperty());
        embers.heightProperty().bind(root.heightProperty());
        root.getChildren().add(embers);

        Polygon diamond = new Polygon(0.0, -35.0, 25.0, 0.0, 0.0, 35.0, -25.0, 0.0);
        diamond.setFill(Color.TRANSPARENT);
        diamond.setStroke(Color.web(C_GOLD));
        diamond.setStrokeWidth(2);
        diamond.setEffect(new Glow(0.6));
        RotateTransition rt = new RotateTransition(Duration.seconds(2.0), diamond);
        rt.setByAngle(360); rt.setCycleCount(Animation.INDEFINITE);
        rt.setInterpolator(Interpolator.LINEAR); rt.play();

        Polygon inner = new Polygon(0.0, -18.0, 13.0, 0.0, 0.0, 18.0, -13.0, 0.0);
        inner.setFill(Color.web(C_CRIMSON, 0.8));
        RotateTransition rt2 = new RotateTransition(Duration.seconds(1.2), inner);
        rt2.setByAngle(-360); rt2.setCycleCount(Animation.INDEFINITE);
        rt2.setInterpolator(Interpolator.LINEAR); rt2.play();

        StackPane spinner = new StackPane(diamond, inner);
        spinner.setPrefSize(80, 80);

        Label loadText = new Label("AWAKENING THE BOARD...");
        loadText.setFont(trackedFont(12));
        loadText.setTextFill(Color.web(C_GOLD));

        FadeTransition ftText = new FadeTransition(Duration.seconds(1.0), loadText);
        ftText.setFromValue(0.3); ftText.setToValue(1.0);
        ftText.setCycleCount(Animation.INDEFINITE); ftText.setAutoReverse(true); ftText.play();

        VBox center = new VBox(30, spinner, loadText);
        center.setAlignment(Pos.CENTER);
        root.getChildren().add(center);

        Scene loadScene = new Scene(root, W, H);
        window.setScene(loadScene);

        new Thread(() -> {
            try { Thread.sleep(2200); } catch (InterruptedException ex) { ex.printStackTrace(); }
            Platform.runLater(() -> initializeGameEngine());
        }).start();
    }

