    private double getCX() {
        double w = boardPane.getWidth();
        if (w == 0) w = W;
        return (w - 350) / 2.0;
    }

    private double getCY() {
        double h = boardPane.getHeight();
        if (h == 0) h = H;
        return (h / 2.0) - 30; // Shift up slightly to leave room for cards/buttons
    }

    private void updateUI() {
        boardPane.getChildren().removeIf(n ->
            (n.getId() != null && (n.getId().startsWith("trackCell") ||
                                    n.getId().startsWith("safeCell")  ||
                                    n.getId().startsWith("homeMarble")||
                                    n.getId().startsWith("playerInfo")||
                                    n.getId().startsWith("boardMarble"))));
        handPane.getChildren().clear();

        drawTrackAndMarbles();
        drawPlayerInfoPanels();
        drawHumanHand();
        updateFirepit();

        String active = game.getActivePlayerColour().toString();
        String next   = game.getNextPlayerColour().toString();
        fadeText(turnLabel,       toDisplayName(active));
        fadeText(nextPlayerLabel, toDisplayName(next));
    }

    private void fadeText(Label lbl, String newText) {
        FadeTransition out = new FadeTransition(Duration.millis(120), lbl);
        out.setToValue(0);
        out.setOnFinished(e -> {
            lbl.setText(newText);
            FadeTransition in = new FadeTransition(Duration.millis(200), lbl);
            in.setToValue(1); in.play();
        });
        out.play();
    }

    private String toDisplayName(String colour) {
        switch (colour) {
            case "RED":    return "Crimson Clan";
            case "BLUE":   return "Sapphire Clan";
            case "GREEN":  return "Jade Clan";
            case "YELLOW": return "Golden Clan";
            default:       return colour;
        }
    }

    private void setControlsEnabled(boolean enabled) {
        handPane.setDisable(!enabled);
        controlsPane.setDisable(!enabled);
