    private void handleHumanTurn() {
        Player human = game.getPlayers().get(0);
        Card selected = human.getSelectedCard();
        if (selected == null) {
            showCustomAlert("Fate Unchosen", "Please select a card from your hand.");
            return;
        }
        if (selected instanceof Seven && guiSelectedMarbles.size() == 2) {
            Integer res = showSplitDialog();
            if (res == null) return;
            try { game.editSplitDistance(res); }
            catch (SplitOutOfRangeException ex) {
                showCustomAlert("Invalid Split", ex.getMessage()); return;
            }
        }
        try {
            int preSize = human.getMarbles().size();
            String cardName = selected.getName();
            game.playPlayerTurn();
            game.endPlayerTurn();
            updateLog(human.getName() + "  ·  executed  " + cardName);
            guiSelectedMarbles.clear();
            cardDescLabel.setText("Select a card to view its power...");
            updateUI();
            if (human.getMarbles().size() > preSize) {
                updateLog("⚠  SHADOW TRAP  ·  spirit lost");
                showCustomAlert("Trap Triggered", "A spirit stepped into darkness and returned to the void.");
            }
            Colour w = game.checkWin();
            if (w != null) { announceWinner(w); return; }
            executeCPUTurns();
        } catch (GameException e) {
            showCustomAlert("Forbidden Path", e.getMessage());
            game.deselectAll(); guiSelectedMarbles.clear(); updateUI();
        }
    }

    private void handleDiscardTurn() {
        Player human = game.getPlayers().get(0);
        if (human.getSelectedCard() == null) {
            showCustomAlert("Fate Unchosen", "Select a card to throw into the void.");
            return;
        }
        updateLog(human.getName() + "  ·  discarded and waited");
        try { game.endPlayerTurn(); } catch (Exception ignored) {}
        guiSelectedMarbles.clear(); 
        cardDescLabel.setText("Select a card to view its power...");
        updateUI(); 
        executeCPUTurns();
    }

    private void executeCPUTurns() {
        if (cpuTimeline != null && cpuTimeline.getStatus() == Timeline.Status.RUNNING) return;
        setControlsEnabled(false);

        cpuTimeline = new Timeline();
        KeyFrame kf = new KeyFrame(Duration.seconds(1.2), e -> {
            Player human = game.getPlayers().get(0);
            if (game.getActivePlayerColour() == human.getColour()) {
                if (!game.canPlayTurn()) {
                    updateLog(human.getName() + "  ·  no souls – skipping");
                    try { game.endPlayerTurn(); } catch (Exception ignored) {}
                    guiSelectedMarbles.clear(); updateUI();
                } else {
                    setControlsEnabled(true); cpuTimeline.stop();
                }
            } else {
                Player active = null;
                for (Player p : game.getPlayers())
                    if (p.getColour() == game.getActivePlayerColour()) { active = p; break; }
                if (active instanceof CPU) {
                    if (game.canPlayTurn()) {
                        try { active.play(); } catch (Exception ignored) {}
                    }
                    try { game.endPlayerTurn(); } catch (Exception ignored) {}
                    updateUI();
                    ArrayList<Card> fp = game.getFirePit();
                    String card = "—";
                    for (int i = fp.size()-1; i >= 0; i--)
                        if (fp.get(i) != null) { card = fp.get(i).getName(); break; }
                    updateLog(active.getName() + "  ·  " + card);
                    Colour w = game.checkWin();
                    if (w != null) { announceWinner(w); cpuTimeline.stop(); }
                }
            }
        });
        cpuTimeline.getKeyFrames().add(kf);
        cpuTimeline.setCycleCount(Timeline.INDEFINITE);
        cpuTimeline.play();
    }

    private void announceWinner(Colour winner) {
        updateLog("⚔  HONOR OBTAINED  ·  " + winner + " prevails.");
        StackPane overlay = new StackPane();
        overlay.setStyle("-fx-background-color: rgba(0,0,0,0.0);");
        overlay.setPickOnBounds(false);

        Rectangle dimmer = new Rectangle();
        dimmer.widthProperty().bind(boardPane.widthProperty());
        dimmer.heightProperty().bind(boardPane.heightProperty());
        dimmer.setFill(Color.web(C_BG_DEEP, 0.0));

        Label win = new Label("VICTORY");
        win.setFont(Font.font("Georgia", FontWeight.BOLD, 100));
        win.setTextFill(Color.web(C_GOLD));
        win.setEffect(new DropShadow(40, Color.web(C_GOLD, 0.5)));

        Label clan = new Label(toDisplayName(winner.toString()).toUpperCase() + "  CONQUERS THE PATH");
        clan.setFont(trackedFont(18));
        clan.setTextFill(Color.web(C_TEXT_MAIN));

        Canvas stroke = makeBrushStroke(600, 16, C_CRIMSON);

        Button menu = buildActionButton("RETURN TO MENU", C_GOLD);
        menu.setOnAction(e -> {
            if (cpuTimeline != null) cpuTimeline.stop();
            FadeTransition ft = new FadeTransition(Duration.millis(800), boardPane);
            ft.setToValue(0);
            ft.setOnFinished(ev -> { createMainMenu(); window.setScene(menuScene); });
            ft.play();
        });

        VBox box = new VBox(20, win, stroke, clan, menu);
        box.setAlignment(Pos.CENTER);

        overlay.getChildren().addAll(dimmer, box);
        AnchorPane.setTopAnchor(overlay, 0.0);
        AnchorPane.setBottomAnchor(overlay, 0.0);
        AnchorPane.setLeftAnchor(overlay, 0.0);
        AnchorPane.setRightAnchor(overlay, 0.0);
        boardPane.getChildren().add(overlay);

        FadeTransition fd = new FadeTransition(Duration.millis(800), dimmer);
        fd.setToValue(0.85); fd.play();

        FadeTransition fv = new FadeTransition(Duration.millis(1200), box);
        fv.setFromValue(0); fv.setToValue(1); fv.setDelay(Duration.millis(400)); fv.play();

        ScaleTransition sv = new ScaleTransition(Duration.millis(1200), win);
        sv.setFromX(0.7); sv.setToX(1.0);
        sv.setFromY(0.7); sv.setToY(1.0);
        sv.setInterpolator(Interpolator.EASE_OUT); sv.setDelay(Duration.millis(400)); sv.play();
    }

