    private void drawTrackAndMarbles() {
        ArrayList<Cell> track = game.getBoard().getTrack();
        for (int i = 0; i < track.size(); i++) {
            Cell cell = track.get(i);
            double[] coords = getCrossCoordinates(i);
            drawCell(cell, coords[0], coords[1], i);
            if (cell.getMarble() != null)
                drawMarble(cell.getMarble(), coords[0], coords[1]);
        }

        for (SafeZone zone : game.getBoard().getSafeZones()) {
            int idx = 0;
            for (Cell cell : zone.getCells()) {
                double[] coords = getSafeZoneCoords(zone.getColour(), idx++);
                drawSafeCell(cell, zone.getColour(), coords[0], coords[1]);
                if (cell.getMarble() != null)
                    drawMarble(cell.getMarble(), coords[0], coords[1]);
            }
        }

        for (Player p : game.getPlayers()) {
            double[] homeBase = getHomeZoneCoords(p.getColour());
            int count = 0;
            for (Marble m : p.getMarbles()) {
                double mx = homeBase[0] + (count % 2) * 28;
                double my = homeBase[1] + (count / 2) * 28;
                drawHomeMarble(m, mx, my);
                count++;
            }
        }
    }

    private void drawCell(Cell cell, double cx, double cy, int trackIndex) {
        Circle c = new Circle(cx, cy, CELL_SIZE / 2.0);
        
        if (cell.getCellType() == CellType.BASE) {
            c.setFill(Color.web(C_GOLD, 0.4)); 
            c.setStroke(Color.web(C_GOLD, 0.9));
            c.setEffect(new DropShadow(10, Color.web(C_GOLD, 0.5)));
        } else if (cell.getCellType() == CellType.ENTRY) {
            c.setFill(Color.web(C_TEXT_MAIN, 0.2)); 
            c.setStroke(Color.web(C_TEXT_MAIN, 0.6));
        } else if (cell.isTrap()) {
            c.setFill(Color.web(C_CRIMSON, 0.3)); 
            c.setStroke(Color.web(C_CRIMSON, 0.8));
            c.setEffect(new DropShadow(5, Color.web(C_CRIMSON, 0.5)));
        } else {
            c.setFill(Color.web(C_TRACK_CELL, 0.9));
            c.setStroke(Color.web(C_TRACK_BRD, 0.6));
        }
        c.setStrokeWidth(1.5);
        c.setStrokeType(StrokeType.INSIDE);
        c.setId("trackCell_" + trackIndex);
        boardPane.getChildren().add(c);
    }

    private void drawSafeCell(Cell cell, Colour colour, double cx, double cy) {
        Circle c = new Circle(cx, cy, CELL_SIZE / 2.0);
        Color base = getJavaColor(colour);
        c.setFill(new Color(base.getRed(), base.getGreen(), base.getBlue(), 0.3));
        c.setStroke(new Color(base.getRed(), base.getGreen(), base.getBlue(), 0.8));
        c.setStrokeWidth(1.5);
        c.setId("safeCell");
        boardPane.getChildren().add(c);
    }

    private void drawMarble(Marble marble, double cx, double cy) {
        double r  = CELL_SIZE / 2.4;
        Color base   = getJavaColor(marble.getColour());
        Color bright = base.brighter().brighter();

        Circle body = new Circle(cx, cy, r);
        body.setFill(new RadialGradient(
            -45, 0.6, cx - r * 0.3, cy - r * 0.3, r * 1.2, false, CycleMethod.NO_CYCLE,
            new Stop(0,   bright),
            new Stop(0.5, base),
            new Stop(1,   base.darker().darker())
        ));
        body.setStroke(Color.web(C_BG_DEEP));
        body.setStrokeWidth(1.0);
        body.setId("boardMarble");

        DropShadow ds = new DropShadow(8, base);
        body.setEffect(ds);

        ScaleTransition pop = new ScaleTransition(Duration.millis(300), body);
        pop.setFromX(0); pop.setFromY(0);
        pop.setToX(1); pop.setToY(1);
        pop.setInterpolator(Interpolator.EASE_OUT);
        pop.play();

        boolean isSelected = guiSelectedMarbles.contains(marble);
        if (isSelected) {
            body.setStroke(Color.web(C_TEXT_MAIN));
            body.setStrokeWidth(2.5);
            ds.setRadius(15); ds.setColor(Color.web(C_TEXT_MAIN));
        }

        body.setOnMouseClicked(e -> {
            if (controlsPane.isDisabled()) return;
            try {
                game.selectMarble(marble);
                guiSelectedMarbles.add(marble);
                updateUI();
            } catch (GameException ex) {
                showCustomAlert("Invalid Target", ex.getMessage());
            }
        });
        body.setCursor(javafx.scene.Cursor.HAND);
        boardPane.getChildren().add(body);
    }

    private void drawHomeMarble(Marble marble, double cx, double cy) {
        double r = CELL_SIZE / 3.0;
