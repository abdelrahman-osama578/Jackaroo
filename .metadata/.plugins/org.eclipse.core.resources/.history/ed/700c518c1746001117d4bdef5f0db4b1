    private void initializeGameEngine() {
        String playerName = showNameDialog();

        try {
            game = new Game(playerName);
        } catch (IOException e) {
            showCustomAlert("Fractured Realm", "Could not load Cards.csv: " + e.getMessage());
            window.setScene(menuScene);
            return;
        }

        boardPane = new AnchorPane();

        Rectangle bg = new Rectangle();
        bg.widthProperty().bind(boardPane.widthProperty());
        bg.heightProperty().bind(boardPane.heightProperty());
        bg.setFill(Color.web(C_BG_DEEP));
        boardPane.getChildren().add(bg);

        emberCanvas = buildEmberCanvas();
        emberCanvas.widthProperty().bind(boardPane.widthProperty());
        emberCanvas.heightProperty().bind(boardPane.heightProperty());
        boardPane.getChildren().add(emberCanvas);

        // Right Panel Dark Backdrop (Anchored to Right)
        Rectangle rightPanel = new Rectangle(350, H);
        rightPanel.heightProperty().bind(boardPane.heightProperty());
        rightPanel.setFill(Color.web(C_BG_MID, 0.85));
        rightPanel.setStroke(Color.web(C_GOLD, 0.3));
        rightPanel.setStrokeWidth(1);
        AnchorPane.setRightAnchor(rightPanel, 0.0);
        AnchorPane.setTopAnchor(rightPanel, 0.0);
        boardPane.getChildren().add(rightPanel);

        setupGameUIComponents();
        updateUI();

        gameScene = new Scene(boardPane, W, H);
        
        // Listeners for Resizing/Fullscreen
        window.widthProperty().addListener((obs, oldV, newV) -> { if (game != null) updateUI(); });
        window.heightProperty().addListener((obs, oldV, newV) -> { if (game != null) updateUI(); });

        gameScene.setOnKeyPressed(e -> {
            if (e.getCode() == KeyCode.F && !controlsPane.isDisabled()) {
                try {
                    game.fieldMarble();
                    updateLog(game.getPlayers().get(0).getName() + "  ·  fielded a spirit [F]");
                    guiSelectedMarbles.clear();
                    updateUI();
                } catch (GameException ex) {
                    showCustomAlert("Path Blocked", ex.getMessage());
                }
            } else if (e.getCode() == KeyCode.F11) {
                window.setFullScreen(!window.isFullScreen());
            }
        });

        window.setScene(gameScene);
        updateLog("The trial begins. Step carefully, " + playerName + ".");

        boardPane.setOpacity(0);
        FadeTransition ft = new FadeTransition(Duration.millis(1000), boardPane);
        ft.setToValue(1); ft.play();
    }

