    private double[] getCrossCoordinates(int index) {
        double cx = getCX();
        double cy = getCY();
        double R = 300; // Tighter radius to prevent clipping
        double angle = -Math.PI / 2 + (index * 2 * Math.PI / 100);
        return new double[]{cx + R * Math.cos(angle), cy + R * Math.sin(angle)};
    }

    private double[] getSafeZoneCoords(Colour c, int idx) {
        int baseIdx = getEngineBaseOffset(c);
        double cx = getCX();
        double cy = getCY();
        double R = 300 - (idx + 1) * 28; 
        double angle = -Math.PI / 2 + (baseIdx * 2 * Math.PI / 100);
        return new double[]{cx + R * Math.cos(angle), cy + R * Math.sin(angle)};
    }

    private double[] getHomeZoneCoords(Colour c) {
        int baseIdx = getEngineBaseOffset(c);
        double cx = getCX();
        double cy = getCY();
        double R = 360; 
        double angle = -Math.PI / 2 + (baseIdx * 2 * Math.PI / 100);
        return new double[]{cx + R * Math.cos(angle) - 14, cy + R * Math.sin(angle) - 14};
    }

    private int getEngineBaseOffset(Colour c) {
        for (int i = 0; i < game.getBoard().getSafeZones().size(); i++)
            if (game.getBoard().getSafeZones().get(i).getColour() == c) return i * 25;
        return 0;
    }

    private Color getJavaColor(Colour c) {
        switch (c) {
            case RED:    return Color.web("#D93838");
            case BLUE:   return Color.web("#4A90E2");
            case GREEN:  return Color.web("#50C878");
            case YELLOW: return Color.web("#F5A623");
            default:     return Color.web(C_TEXT_MAIN);
        }
    }

