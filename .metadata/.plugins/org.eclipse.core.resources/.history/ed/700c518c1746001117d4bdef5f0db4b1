    private void createMainMenu() {
        StackPane root = new StackPane();

        Rectangle bg = new Rectangle();
        bg.widthProperty().bind(root.widthProperty());
        bg.heightProperty().bind(root.heightProperty());
        bg.setFill(new RadialGradient(0, 0, 0.5, 0.5, 1.0, true, CycleMethod.NO_CYCLE,
            new Stop(0, Color.web(C_BG_MID)),
            new Stop(1, Color.web(C_BG_DEEP))));
        root.getChildren().add(bg);

        Canvas embers = buildEmberCanvas();
        embers.widthProperty().bind(root.widthProperty());
        embers.heightProperty().bind(root.heightProperty());
        root.getChildren().add(embers);

        Rectangle inkBand = new Rectangle(500, H);
        inkBand.heightProperty().bind(root.heightProperty());
        inkBand.setFill(new LinearGradient(0, 0, 1, 0, true, CycleMethod.NO_CYCLE,
            new Stop(0, Color.TRANSPARENT),
            new Stop(0.5, Color.web("#000000", 0.4)),
            new Stop(1,   Color.web("#000000", 0.8))));
        StackPane.setAlignment(inkBand, Pos.CENTER_RIGHT);
        root.getChildren().add(inkBand);

        VBox content = new VBox(0);
        content.setAlignment(Pos.CENTER_LEFT);
        content.setPadding(new Insets(0, 0, 0, W * 0.1));
        content.setPickOnBounds(false);
        StackPane.setAlignment(content, Pos.CENTER_LEFT);

        Label sub = new Label("THE SHADOW PATH");
        sub.setFont(trackedFont(14));
        sub.setTextFill(Color.web(C_CRIMSON));
        sub.setPadding(new Insets(0, 0, 12, 4));

        Label title = new Label("JACKAROO");
        title.setFont(Font.font("Georgia", FontWeight.BOLD, 100));
        title.setTextFill(Color.web(C_TEXT_MAIN));
        title.setEffect(new DropShadow(15, Color.web(C_GOLD, 0.2)));

        Canvas brushStroke = makeBrushStroke(500, 14, C_GOLD);
        brushStroke.setTranslateY(-4);

        VBox.setMargin(sub,         new Insets(80, 0, 0, 0));
        VBox.setMargin(brushStroke, new Insets(0,  0, 50, 0));

        VBox menu = new VBox(0);
        menu.setAlignment(Pos.CENTER_LEFT);

        String[][] items = {
            {"BEGIN TALE",   C_GOLD},
            {"VIEW SCROLLS", C_TEXT_MAIN},
            {"DEPART",       C_TEXT_DIM}
        };
        for (int i = 0; i < items.length; i++) {
            final int idx = i;
            Label lbl = buildMenuEntry(items[i][0], items[i][1], i == 0);
            lbl.setOnMouseClicked(e -> {
                switch(idx) {
                    case 0: triggerLoadingScreen(); break;
                    case 1: showRulesScreen(); break;
                    case 2: window.close(); break;
                }
            });
            menu.getChildren().add(lbl);
            if (i < items.length - 1) {
                Line sep = new Line(0, 0, 300, 0);
                sep.setStroke(Color.web(C_TRACK_BRD, 0.3));
                VBox.setMargin(sep, new Insets(0));
                menu.getChildren().add(sep);
            }
        }

        content.getChildren().addAll(sub, title, brushStroke, menu);
        root.getChildren().add(buildDiamondCluster());

        root.getChildren().add(content);
        menuScene = new Scene(root, W, H);

        content.setOpacity(0);
        FadeTransition ft = new FadeTransition(Duration.millis(1200), content);
        ft.setToValue(1);
        ft.setDelay(Duration.millis(300));
        ft.play();
    }

    private Label buildMenuEntry(String text, String colorHex, boolean selected) {
        Label lbl = new Label(text);
        lbl.setFont(trackedFont(18));
        lbl.setTextFill(Color.web(colorHex));
        lbl.setPadding(new Insets(20, 40, 20, selected ? 22 : 24));
        lbl.setCursor(javafx.scene.Cursor.HAND);

        if (selected) {
            lbl.setStyle("-fx-border-color: " + C_CRIMSON + " transparent transparent transparent;" +
                         "-fx-border-width: 0 0 0 4;" +
                         "-fx-padding: 20 40 20 22;");
        }

        lbl.setOnMouseEntered(e -> {
            lbl.setTextFill(Color.web(C_CRIMSON));
            ScaleTransition st = new ScaleTransition(Duration.millis(150), lbl);
            st.setToX(1.05); st.setToY(1.05); st.play();
        });
        lbl.setOnMouseExited(e -> {
            lbl.setTextFill(Color.web(colorHex));
            ScaleTransition st = new ScaleTransition(Duration.millis(150), lbl);
            st.setToX(1.0); st.setToY(1.0); st.play();
        });
        return lbl;
    }

