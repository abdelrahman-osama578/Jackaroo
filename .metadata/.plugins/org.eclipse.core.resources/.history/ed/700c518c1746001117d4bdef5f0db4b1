    private Canvas buildEmberCanvas() {
        Canvas canvas = new Canvas(W, H);
        canvas.setMouseTransparent(true);

        for (int i = 0; i < px.length; i++) {
            px[i]   = rng.nextFloat() * (float)W;
            py[i]   = rng.nextFloat() * (float)H;
            pdx[i]  = (rng.nextFloat() - 0.5f) * 0.8f; 
            pdy[i]  = -(rng.nextFloat() * 1.5f + 0.5f); 
            palp[i] = rng.nextFloat() * 0.6f + 0.1f;
        }

        if (emberTimeline != null) emberTimeline.stop();
        emberTimeline = new Timeline(new KeyFrame(Duration.millis(30), e -> {
            double w = canvas.getWidth();
            double h = canvas.getHeight();
            if (w == 0 || h == 0) return;

            GraphicsContext gc = canvas.getGraphicsContext2D();
            gc.clearRect(0, 0, w, h);
            
            if (!showEmbers) return; 

            for (int i = 0; i < px.length; i++) {
                px[i] += pdx[i];
                py[i] += pdy[i];
                if (px[i] < 0)  px[i] = (float)w;
                if (px[i] > w)  px[i] = 0;
                if (py[i] < 0)  { py[i] = (float)h; px[i] = rng.nextFloat() * (float)w; } 

                double radius = 1 + rng.nextDouble() * 3; 
                gc.setFill(new Color(emberColor.getRed(), emberColor.getGreen(), emberColor.getBlue(), palp[i]));
                gc.fillOval(px[i], py[i], radius * 2, radius * 2);
                
                gc.setFill(new RadialGradient(0, 0, px[i]+radius, py[i]+radius, radius*4, false, CycleMethod.NO_CYCLE,
                    new Stop(0, new Color(emberColor.getRed(), emberColor.getGreen(), emberColor.getBlue(), palp[i]*0.5)),
                    new Stop(1, Color.TRANSPARENT)));
                gc.fillOval(px[i] - radius*3, py[i] - radius*3, radius * 8, radius * 8);
            }
        }));
        emberTimeline.setCycleCount(Animation.INDEFINITE);
        emberTimeline.play();

        return canvas;
    }

    private Canvas makeBrushStroke(double w, double h, String colorHex) {
        Canvas c = new Canvas(w, h);
        GraphicsContext gc = c.getGraphicsContext2D();
        double midY = h / 2.0;
        for (int i = 0; i < (int)w; i++) {
            double progress = i / w;
            double thick = h * (0.2 + 0.8 * Math.sin(Math.PI * progress));
            double alpha = 0.5 + 0.5 * Math.sin(Math.PI * progress) - 0.2 * rng.nextDouble();
            gc.setFill(Color.web(colorHex, Math.max(0.1, alpha)));
            gc.fillRect(i, midY - thick / 2, 1.5, thick);
        }
        return c;
    }

    private Canvas buildInlineSep(double width) {
        Canvas c = new Canvas(width, 2);
        c.getGraphicsContext2D().setFill(Color.web(C_GOLD, 0.3));
        c.getGraphicsContext2D().fillRect(0, 0, width, 2);
        return c;
    }

    private StackPane buildDiamondCluster() {
        StackPane sp = new StackPane();
        sp.setPrefSize(200, 200);
        StackPane.setAlignment(sp, Pos.CENTER_RIGHT);
        sp.setTranslateX(-60);
        sp.setMouseTransparent(true);

        int[] sizes = {120, 80, 50, 25};
        for (int s : sizes) {
            Polygon d = new Polygon(0.0, -(double)s, (double)s, 0.0, 0.0, (double)s, -(double)s, 0.0);
            d.setFill(Color.TRANSPARENT);
            d.setStroke(Color.web(C_CRIMSON, 0.15));
            d.setStrokeWidth(1.5);
            sp.getChildren().add(d);

            RotateTransition rt = new RotateTransition(Duration.seconds(25 + s / 3.0), d);
            rt.setByAngle(s % 2 == 0 ? 360 : -360);
            rt.setCycleCount(Animation.INDEFINITE);
            rt.setInterpolator(Interpolator.LINEAR);
            rt.play();
        }
        return sp;
    }

    private Button buildActionButton(String text, String colorHex) {
        Button btn = new Button(text);
        btn.setFont(trackedFont(12));
        btn.setTextFill(Color.web(colorHex));
        btn.setCursor(javafx.scene.Cursor.HAND);
        btn.setStyle(
            "-fx-background-color: transparent;" +
            "-fx-padding: 12 25 12 25;" +
            "-fx-border-color: " + colorHex + ";" +
            "-fx-border-width: 2;" +
            "-fx-border-radius: 4;"
        );
        btn.setOnMouseEntered(e -> {
            btn.setStyle(
                "-fx-background-color: " + colorHex + ";" +
                "-fx-padding: 12 25 12 25;" +
                "-fx-border-color: " + colorHex + ";" +
                "-fx-border-width: 2;" +
                "-fx-border-radius: 4;"
            );
            btn.setTextFill(Color.web(C_BG_DEEP)); 
        });
        btn.setOnMouseExited(e -> {
            btn.setStyle(
                "-fx-background-color: transparent;" +
                "-fx-padding: 12 25 12 25;" +
                "-fx-border-color: " + colorHex + ";" +
                "-fx-border-width: 2;" +
                "-fx-border-radius: 4;"
            );
            btn.setTextFill(Color.web(colorHex));
        });
        return btn;
    }

    private Font trackedFont(double size) {
        return Font.font("Georgia", FontWeight.BOLD, size);
    }

    private String trackedText(String s) {
        StringBuilder sb = new StringBuilder();
        for (char c : s.toCharArray()) { sb.append(c); sb.append(' '); }
        return sb.toString().trim();
    }

