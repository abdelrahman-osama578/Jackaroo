    private void drawTrackAndMarbles() {
        ArrayList<Cell> track = game.getBoard().getTrack();
        for (int i = 0; i < track.size(); i++) {
            Cell cell = track.get(i);
            double[] coords = getCrossCoordinates(i);
            drawCell(cell, coords[0], coords[1], i);
            if (cell.getMarble() != null)
                drawMarble(cell.getMarble(), coords[0], coords[1]);
        }

        for (SafeZone zone : game.getBoard().getSafeZones()) {
            int idx = 0;
            for (Cell cell : zone.getCells()) {
                double[] coords = getSafeZoneCoords(zone.getColour(), idx++);
                drawSafeCell(cell, zone.getColour(), coords[0], coords[1]);
                if (cell.getMarble() != null)
                    drawMarble(cell.getMarble(), coords[0], coords[1]);
            }
        }

        for (Player p : game.getPlayers()) {
            double[] homeBase = getHomeZoneCoords(p.getColour());
            int count = 0;
            for (Marble m : p.getMarbles()) {
                double mx = homeBase[0] + (count % 2) * 26;
                double my = homeBase[1] + (count / 2) * 26;
                drawHomeMarble(m, mx, my);
                count++;
            }
        }
    }

    private void drawCell(Cell cell, double x, double y, int trackIndex) {
        Rectangle rect = new Rectangle(x + 1, y + 1, CELL_SIZE - 2, CELL_SIZE - 2);
        rect.setArcWidth(2); rect.setArcHeight(2);

        if (cell.getCellType() == CellType.BASE) {
            rect.setFill(Color.web("#D4C88A", 0.6)); 
            rect.setStroke(Color.web(C_GOLD, 0.8));
        } else if (cell.getCellType() == CellType.ENTRY) {
            rect.setFill(Color.web("#C8D4A0", 0.6)); 
            rect.setStroke(Color.web("#7A9A30", 0.7));
        } else if (cell.isTrap()) {
            rect.setFill(Color.web("#2A1A18", 0.25)); 
            rect.setStroke(Color.web(C_CRIMSON, 0.5));
        } else {
            rect.setFill(Color.web(C_TRACK_CELL, 0.8));
            rect.setStroke(Color.web(C_TRACK_BRD, 0.5));
        }
        rect.setStrokeWidth(1);
        rect.setId("trackCell_" + trackIndex);
        boardPane.getChildren().add(rect);
    }

    private void drawSafeCell(Cell cell, Colour colour, double x, double y) {
        Rectangle sr = new Rectangle(x + 1, y + 1, CELL_SIZE - 2, CELL_SIZE - 2);
        sr.setArcWidth(2); sr.setArcHeight(2);
        Color base = getJavaColor(colour);
        sr.setFill(new Color(base.getRed(), base.getGreen(), base.getBlue(), 0.22));
        sr.setStroke(new Color(base.getRed(), base.getGreen(), base.getBlue(), 0.55));
        sr.setStrokeWidth(1.2);
        sr.setId("safeCell");
        boardPane.getChildren().add(sr);
    }

    private void drawMarble(Marble marble, double x, double y) {
        double cx = x + CELL_SIZE / 2.0;
        double cy = y + CELL_SIZE / 2.0;
        double r  = CELL_SIZE / 2.2;

        Color base   = getJavaColor(marble.getColour());
        Color bright = base.brighter().brighter();

        Circle glow = new Circle(cx, cy, r + 3);
        glow.setFill(new Color(base.getRed(), base.getGreen(), base.getBlue(), 0.15));

        Circle body = new Circle(cx, cy, r);
        body.setFill(new RadialGradient(
            -45, 0.6, cx - r * 0.3, cy - r * 0.3, r * 1.2, false, CycleMethod.NO_CYCLE,
            new Stop(0,   bright),
            new Stop(0.5, base),
            new Stop(1,   base.darker())
        ));
        body.setStroke(Color.web(C_INK, 0.4));
        body.setStrokeWidth(0.8);

        Circle highlight = new Circle(cx - r * 0.3, cy - r * 0.3, r * 0.28);
        highlight.setFill(Color.web("#FFFFFF", 0.55));

        boolean isSelected = guiSelectedMarbles.contains(marble);
        if (isSelected) {
            body.setStroke(Color.web(C_GOLD));
            body.setStrokeWidth(2.5);
            DropShadow sel = new DropShadow(8, Color.web(C_GOLD, 0.7));
            body.setEffect(sel);
        }

        body.setOnMouseClicked(e -> {
            if (controlsPane.isDisabled()) return;
            try {
                game.selectMarble(marble);
                guiSelectedMarbles.add(marble);
                ScaleTransition st = new ScaleTransition(Duration.millis(180), body);
                st.setFromX(1.0); st.setToX(1.25);
                st.setFromY(1.0); st.setToY(1.25);
                st.setAutoReverse(true); st.setCycleCount(2); st.play();
                updateUI();
            } catch (GameException ex) {
                showAlert(Alert.AlertType.WARNING, "Invalid", ex.getMessage());
            }
        });
        body.setCursor(javafx.scene.Cursor.HAND);

        boardPane.getChildren().addAll(glow, body, highlight);
    }

    private void drawHomeMarble(Marble marble, double x, double y) {
        double r = CELL_SIZE / 2.8;
        Color base = getJavaColor(marble.getColour());
        Circle c = new Circle(x + r, y + r, r);
