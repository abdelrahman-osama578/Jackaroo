    private double[] getCrossCoordinates(int index) {
        int side = index / 25;
        int pos  = index % 25;
        double ox = 195, oy = 100;
        double x, y;
        if      (side == 0) { x = ox + pos * CELL_SIZE; y = oy; }
        else if (side == 1) { x = ox + 25 * CELL_SIZE;  y = oy + pos * CELL_SIZE; }
        else if (side == 2) { x = ox + (25 - pos) * CELL_SIZE; y = oy + 25 * CELL_SIZE; }
        else                { x = ox; y = oy + (25 - pos) * CELL_SIZE; }
        return new double[]{x, y};
    }

    private double[] getSafeZoneCoords(Colour c, int idx) {
        double[] base = getCrossCoordinates(getEngineBaseOffset(c));
        return new double[]{base[0] + 26, base[1] + 26 + idx * CELL_SIZE};
    }

    private double[] getHomeZoneCoords(Colour c) {
        switch (c) {
            case RED:    return new double[]{168, 108};
            case BLUE:   return new double[]{720, 108};
            case GREEN:  return new double[]{720, 650};
            case YELLOW: return new double[]{168, 650};
            default:     return new double[]{0, 0};
        }
    }

    private int getEngineBaseOffset(Colour c) {
        for (int i = 0; i < game.getBoard().getSafeZones().size(); i++)
            if (game.getBoard().getSafeZones().get(i).getColour() == c) return i * 25;
        return 0;
    }

    private Color getJavaColor(Colour c) {
        switch (c) {
            case RED:    return Color.web("#CC3030");
            case BLUE:   return Color.web("#2070CC");
            case GREEN:  return Color.web("#287A30");
            case YELLOW: return Color.web("#C8A030");
            default:     return Color.web(C_INK);
        }
    }

