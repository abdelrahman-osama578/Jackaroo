            (n.getId() != null && (n.getId().startsWith("trackCell") ||
                                    n.getId().startsWith("marbLabel") ||
                                    n.getId().startsWith("safeCell")  ||
                                    n.getId().startsWith("homeMarble")||
                                    n.getId().startsWith("playerInfo"))));
        handPane.getChildren().clear();

        drawTrackAndMarbles();
        drawPlayerInfoPanels();
        drawHumanHand();
        updateFirepit();

        String active = game.getActivePlayerColour().toString();
        String next   = game.getNextPlayerColour().toString();
        fadeText(turnLabel,       toDisplayName(active));
        fadeText(nextPlayerLabel, toDisplayName(next));
    }

    private void fadeText(Label lbl, String newText) {
        FadeTransition out = new FadeTransition(Duration.millis(120), lbl);
        out.setToValue(0);
        out.setOnFinished(e -> {
            lbl.setText(newText);
            FadeTransition in = new FadeTransition(Duration.millis(200), lbl);
            in.setToValue(1); in.play();
        });
        out.play();
    }

    private String toDisplayName(String colour) {
        switch (colour) {
            case "RED":    return "Red  Clan";
            case "BLUE":   return "Blue  Clan";
            case "GREEN":  return "Green  Clan";
            case "YELLOW": return "Gold  Clan";
            default:       return colour;
        }
    }

