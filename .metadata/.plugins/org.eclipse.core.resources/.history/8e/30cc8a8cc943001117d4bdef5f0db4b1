    private void triggerLoadingScreen() {
        StackPane root = new StackPane();
        Rectangle bg = new Rectangle(W, H);
        bg.setFill(new LinearGradient(0, 0, 0, 1, true, CycleMethod.NO_CYCLE,
            new Stop(0, Color.web("#F0EDE7")),
            new Stop(1, Color.web("#C0BDB6"))));
        root.getChildren().add(bg);
        root.getChildren().add(buildMistCanvas((int)W, (int)H));

        Polygon diamond = new Polygon(0.0, -28.0, 20.0, 0.0, 0.0, 28.0, -20.0, 0.0);
        diamond.setFill(Color.TRANSPARENT);
        diamond.setStroke(Color.web(C_GOLD));
        diamond.setStrokeWidth(2);
        RotateTransition rt = new RotateTransition(Duration.seconds(1.6), diamond);
        rt.setByAngle(360); rt.setCycleCount(Animation.INDEFINITE);
        rt.setInterpolator(Interpolator.LINEAR); rt.play();

        Polygon inner = new Polygon(0.0, -14.0, 10.0, 0.0, 0.0, 14.0, -10.0, 0.0);
        inner.setFill(Color.web(C_GOLD, 0.35));
        inner.setStroke(Color.web(C_GOLD, 0.6));
        inner.setStrokeWidth(1.5);
        RotateTransition rt2 = new RotateTransition(Duration.seconds(0.9), inner);
        rt2.setByAngle(-360); rt2.setCycleCount(Animation.INDEFINITE);
        rt2.setInterpolator(Interpolator.LINEAR); rt2.play();

        StackPane spinner = new StackPane(diamond, inner);
        spinner.setPrefSize(60, 60);

        Label loadText = new Label("INITIALIZING  ·  PLEASE WAIT");
        loadText.setFont(trackedFont(11));
        loadText.setTextFill(Color.web(C_INK, 0.7));

        FadeTransition ftText = new FadeTransition(Duration.seconds(0.9), loadText);
        ftText.setFromValue(0.4); ftText.setToValue(1.0);
        ftText.setCycleCount(Animation.INDEFINITE); ftText.setAutoReverse(true); ftText.play();

        VBox center = new VBox(24, spinner, loadText);
        center.setAlignment(Pos.CENTER);
        root.getChildren().add(center);

        Scene loadScene = new Scene(root, W, H);
        window.setScene(loadScene);

        Timeline tl = new Timeline(new KeyFrame(Duration.seconds(2.0), e -> initializeGameEngine()));
        tl.play();
    }

    // ═════════════════════════════════════════════════════════════════════════
    // GAME INIT
    // ═════════════════════════════════════════════════════════════════════════

    private void initializeGameEngine() {
        // GUIDELINE FIX: Use Native JavaFX Dialog instead of Swing JOptionPane
        TextInputDialog dialog = new TextInputDialog("Ronin");
        dialog.setTitle("Identity");
        dialog.setHeaderText(null);
        dialog.setContentText("Enter your warrior's name:");

        Optional<String> result = dialog.showAndWait();
        String playerName = result.isPresent() && !result.get().trim().isEmpty() ? result.get().trim() : "Ronin";

        try {
            game = new Game(playerName);
        } catch (IOException e) {
            showAlert(Alert.AlertType.ERROR, "Error", "Could not load Cards.csv: " + e.getMessage());
            window.setScene(menuScene);
            return;
        }

        boardPane = new AnchorPane();

        Rectangle bg = new Rectangle(W, H);
        bg.setFill(new LinearGradient(0, 0, 0, 1, true, CycleMethod.NO_CYCLE,
            new Stop(0,   Color.web("#EDEAE4")),
            new Stop(0.5, Color.web("#DEDAD2")),
            new Stop(1,   Color.web("#C8C4BC"))));
        boardPane.getChildren().add(bg);

        mistCanvas = buildMistCanvas((int)W, (int)H);
        boardPane.getChildren().add(mistCanvas);

        Rectangle rightPanel = new Rectangle(310, H);
        rightPanel.setFill(new LinearGradient(0, 0, 1, 0, true, CycleMethod.NO_CYCLE,
            new Stop(0, Color.web("#1A1714", 0.0)),
            new Stop(0.15, Color.web("#1A1714", 0.06)),
            new Stop(1,   Color.web("#1A1714", 0.14))));
        AnchorPane.setRightAnchor(rightPanel, 0.0);
        AnchorPane.setTopAnchor(rightPanel, 0.0);
        boardPane.getChildren().add(rightPanel);

        setupGameUIComponents();
        updateUI();

        gameScene = new Scene(boardPane, W, H);

        gameScene.setOnKeyPressed(e -> {
            if (e.getCode() == KeyCode.F && !controlsPane.isDisabled()) {
                try {
                    game.fieldMarble();
                    updateLog(game.getPlayers().get(0).getName() + "  ·  fielded a marble [F]");
                    guiSelectedMarbles.clear();
                    updateUI();
                } catch (GameException ex) {
                    showAlert(Alert.AlertType.WARNING, "Cannot Field", ex.getMessage());
                }
            }
        });

        window.setScene(gameScene);
        updateLog("The game has begun. Welcome, " + playerName + ".");

        boardPane.setOpacity(0);
        FadeTransition ft = new FadeTransition(Duration.millis(700), boardPane);
        ft.setToValue(1); ft.play();
    }

