        root.getChildren().add(hRule(0, 0, 0)); // dummy
        Canvas stroke = makeBrushStroke(360, 12);

        VBox rulesList = new VBox(20);
        String[][] rules = {
            {"I.",  "OBJECTIVE",   "Move all 4 marbles from Home Zone to your Safe Zone to claim victory."},
            {"II.", "FIELDING",    "Play an Ace or King to deploy a marble onto your Base Cell. Press [F] as a field shortcut."},
            {"III.","MOVEMENT",    "Marbles advance clockwise. A Four card moves backward 4 steps. A Five card moves any marble."},
            {"IV.", "TRAPS",       "Eight hidden trap cells lurk on the board — landing on one sends your marble home instantly."},
            {"V.",  "TURN FLOW",   "Select a card, select the required marble(s), then confirm with Play Turn."},
            {"VI.", "SKIP",        "If no valid move exists, select any card and use Discard / Skip to pass your turn."}
        };
        for (String[] rule : rules) {
            HBox row = new HBox(20);
            row.setAlignment(Pos.TOP_LEFT);

            Label num = new Label(rule[0]);
            num.setFont(Font.font("Georgia", FontWeight.BOLD, 14));
            num.setTextFill(Color.web(C_GOLD));
