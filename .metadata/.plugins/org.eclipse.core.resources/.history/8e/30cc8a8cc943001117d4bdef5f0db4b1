        Button back = buildActionButton("← RETURN", C_INK);
        back.setOnAction(e -> {
            FadeTransition ft = new FadeTransition(Duration.millis(350), root);
            ft.setToValue(0);
            ft.setOnFinished(ev -> window.setScene(menuScene));
            ft.play();
        });

        layout.getChildren().addAll(header, title, stroke, rulesList, back);
        root.getChildren().add(layout);

        Scene rulesScene = new Scene(root, W, H);
        window.setScene(rulesScene);
        root.setOpacity(0);
        FadeTransition ft = new FadeTransition(Duration.millis(600), root);
        ft.setToValue(1); ft.play();
    }

