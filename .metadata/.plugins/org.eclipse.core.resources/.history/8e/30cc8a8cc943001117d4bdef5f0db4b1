        title.setEffect(ds);

        // Brush-stroke underline for title
        Canvas brushStroke = makeBrushStroke(480, 14);
        brushStroke.setTranslateY(-4);

        VBox.setMargin(sub,         new Insets(80, 0, 0, 0));
        VBox.setMargin(brushStroke, new Insets(0,  0, 50, 0));

        // Menu items
        VBox menu = new VBox(0);
        menu.setAlignment(Pos.CENTER_LEFT);

