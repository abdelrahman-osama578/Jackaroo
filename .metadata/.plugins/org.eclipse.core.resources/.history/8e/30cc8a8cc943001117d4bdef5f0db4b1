    private Label buildMenuEntry(String text, String colorHex, boolean selected) {
        Label lbl = new Label(text);
        lbl.setFont(trackedFont(18));
        lbl.setTextFill(Color.web(colorHex));
        lbl.setPadding(new Insets(18, 40, 18, selected ? 22 : 24));
        lbl.setCursor(javafx.scene.Cursor.HAND);

        if (selected) {
            lbl.setStyle(
                "-fx-border-color: " + C_GOLD + " transparent transparent transparent;" +
                "-fx-border-width: 0 0 0 3;" +
                "-fx-padding: 18 40 18 22;"
            );
        }

        lbl.setOnMouseEntered(e -> {
            lbl.setTextFill(Color.web(C_GOLD));
            ScaleTransition st = new ScaleTransition(Duration.millis(150), lbl);
            st.setToX(1.03); st.setToY(1.03); st.play();
        });
        lbl.setOnMouseExited(e -> {
            lbl.setTextFill(Color.web(colorHex));
            ScaleTransition st = new ScaleTransition(Duration.millis(150), lbl);
            st.setToX(1.0); st.setToY(1.0); st.play();
        });

        return lbl;
    }

