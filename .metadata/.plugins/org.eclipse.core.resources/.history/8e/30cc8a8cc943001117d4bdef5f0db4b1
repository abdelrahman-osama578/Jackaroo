    private Canvas buildMistCanvas(int w, int h) {
        Canvas canvas = new Canvas(w, h);
        canvas.setMouseTransparent(true);
        canvas.setOpacity(0.55);

        for (int i = 0; i < px.length; i++) {
            px[i]   = rng.nextFloat() * w;
            py[i]   = rng.nextFloat() * h;
            pdx[i]  = (rng.nextFloat() - 0.5f) * 0.4f;
            pdy[i]  = (rng.nextFloat() - 0.5f) * 0.15f;
            palp[i] = rng.nextFloat() * 0.12f + 0.02f;
        }

        if (mistTimeline != null) mistTimeline.stop();
        mistTimeline = new Timeline(new KeyFrame(Duration.millis(60), e -> {
            GraphicsContext gc = canvas.getGraphicsContext2D();
            gc.clearRect(0, 0, w, h);
            for (int i = 0; i < px.length; i++) {
                px[i] += pdx[i];
                py[i] += pdy[i];
                if (px[i] < 0)  px[i] = w;
                if (px[i] > w)  px[i] = 0;
                if (py[i] < 0)  py[i] = h;
                if (py[i] > h)  py[i] = 0;

                double radius = 60 + rng.nextDouble() * 80;
                RadialGradient rg = new RadialGradient(0, 0,
                    px[i], py[i], radius, false, CycleMethod.NO_CYCLE,
                    new Stop(0,   Color.web("#FDFCFA", palp[i])),
                    new Stop(0.5, Color.web("#F0EDE7", palp[i] * 0.4)),
                    new Stop(1,   Color.TRANSPARENT));
                gc.setFill(rg);
                gc.fillOval(px[i] - radius, py[i] - radius, radius * 2, radius * 2);
            }
        }));
        mistTimeline.setCycleCount(Animation.INDEFINITE);
        mistTimeline.play();

        return canvas;
    }

    private Canvas makeBrushStroke(double w, double h) {
        Canvas c = new Canvas(w, h);
        GraphicsContext gc = c.getGraphicsContext2D();
        double midY = h / 2.0;
        for (int i = 0; i < (int)w; i++) {
            double progress = i / w;
            double thick = h * (0.3 + 0.7 * Math.sin(Math.PI * progress));
            double alpha = 0.55 + 0.45 * Math.sin(Math.PI * progress)
                - 0.15 * rng.nextDouble();
            gc.setFill(Color.web(C_INK, Math.max(0.05, alpha)));
            gc.fillRect(i, midY - thick / 2, 1.2, thick);
        }
        return c;
    }

