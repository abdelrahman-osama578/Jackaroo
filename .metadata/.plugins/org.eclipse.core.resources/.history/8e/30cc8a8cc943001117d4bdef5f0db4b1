            rTitle.setFont(trackedFont(11));
            rTitle.setTextFill(Color.web(C_INK));

            Label rBody = new Label(rule[2]);
            rBody.setFont(Font.font("Georgia", 15));
            rBody.setTextFill(Color.web(C_INK_LIGHT));
            rBody.setWrapText(true);
            rBody.setMaxWidth(700);

            textCol.getChildren().addAll(rTitle, rBody);
            row.getChildren().addAll(num, textCol);
