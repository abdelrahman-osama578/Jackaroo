        layout.setPadding(new Insets(80, 120, 60, 120));

        Label header = new Label("BUSHIDŌ OF JACKAROO");
        header.setFont(trackedFont(11));
        header.setTextFill(Color.web(C_GOLD));

        Label title = new Label("Game Rules");
        title.setFont(Font.font("Georgia", FontWeight.BOLD, 52));
