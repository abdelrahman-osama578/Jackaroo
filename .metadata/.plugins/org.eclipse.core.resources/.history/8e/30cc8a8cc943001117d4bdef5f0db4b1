    }

    private StackPane buildDiamondCluster() {
        StackPane sp = new StackPane();
        sp.setPrefSize(200, 200);
        StackPane.setAlignment(sp, Pos.CENTER_RIGHT);
        sp.setTranslateX(-60);
        sp.setMouseTransparent(true);

        int[] sizes = {80, 56, 34, 18};
        for (int s : sizes) {
            Polygon d = new Polygon(0.0, -(double)s, (double)s, 0.0, 0.0, (double)s, -(double)s, 0.0);
            d.setFill(Color.TRANSPARENT);
            double alpha = 0.04 + (80.0 - s) / 80.0 * 0.06;
            d.setStroke(Color.web(C_GOLD, alpha));
            d.setStrokeWidth(1.2);
            sp.getChildren().add(d);

            RotateTransition rt = new RotateTransition(Duration.seconds(18 + s / 4.0), d);
            rt.setByAngle(s % 2 == 0 ? 360 : -360);
            rt.setCycleCount(Animation.INDEFINITE);
            rt.setInterpolator(Interpolator.LINEAR);
            rt.play();
        }
        return sp;
    }

    private Button buildActionButton(String text, String colorHex) {
        Button btn = new Button(text);
        btn.setFont(trackedFont(10));
        btn.setTextFill(Color.web(colorHex));
        btn.setCursor(javafx.scene.Cursor.HAND);
        btn.setStyle(
            "-fx-background-color: " + C_INK + ";" +
            "-fx-background-radius: 2;" +
            "-fx-padding: 11 22 11 22;" +
            "-fx-border-color: " + colorHex + ";" +
            "-fx-border-width: 1;" +
            "-fx-border-radius: 2;"
        );
        btn.setOnMouseEntered(e -> {
            btn.setStyle(
                "-fx-background-color: " + colorHex + ";" +
                "-fx-background-radius: 2;" +
                "-fx-padding: 11 22 11 22;"
            );
            btn.setTextFill(Color.web(C_INK));
        });
        btn.setOnMouseExited(e -> {
            btn.setStyle(
                "-fx-background-color: " + C_INK + ";" +
                "-fx-background-radius: 2;" +
                "-fx-padding: 11 22 11 22;" +
                "-fx-border-color: " + colorHex + ";" +
                "-fx-border-width: 1;" +
                "-fx-border-radius: 2;"
            );
            btn.setTextFill(Color.web(colorHex));
        });
        return btn;
    }

    private Font trackedFont(double size) {
        return Font.font("Georgia", size);
    }

    private String trackedText(String s) {
        StringBuilder sb = new StringBuilder();
        for (char c : s.toCharArray()) { sb.append(c); sb.append(' '); }
        return sb.toString().trim();
    }

    // GUIDELINE FIX: Use Native JavaFX Dialog instead of Swing JOptionPane
    private void showAlert(Alert.AlertType type, String title, String msg) {
        Alert alert = new Alert(type);
        alert.setTitle(title);
        alert.setHeaderText(null);
        alert.setContentText(msg);
        alert.showAndWait();
    }

    public static void main(String[] args) {
        launch(args);
    }
