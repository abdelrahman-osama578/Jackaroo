    private void handleHumanTurn() {
        Player human = game.getPlayers().get(0);
        Card selected = human.getSelectedCard();

        if (selected == null) {
            showNativeAlert(Alert.AlertType.WARNING, "Fate Unchosen", "Thou must select a card to play.");
            return;
        }

        if (selected instanceof Seven && guiSelectedMarbles.size() == 2) {
            ChoiceDialog<Integer> dialog = new ChoiceDialog<>(3, 1, 2, 3, 4, 5, 6);
            dialog.setTitle("Sever the Path");
            dialog.setHeaderText("How many steps for the first spirit?");
            dialog.setContentText("Steps:");
            dialog.getDialogPane().getStylesheets().add(getBaseCSS());
            
            Optional<Integer> result = dialog.showAndWait();
            if (result.isPresent()) {
                try { game.editSplitDistance(result.get()); } 
                catch (SplitOutOfRangeException ex) { showNativeAlert(Alert.AlertType.ERROR, "Invalid Split", ex.getMessage()); return; }
            } else return; 
        }

        try {
            int preHomeSize = human.getMarbles().size();
            String cardName = selected.getName();
            
            game.playPlayerTurn();
            game.endPlayerTurn();
            
            updateLog(human.getName() + " channeled: " + cardName);
            guiSelectedMarbles.clear();
            updateUI();

            if (human.getMarbles().size() > preHomeSize && !(selected.getName().contains("Burner"))) {
                updateLog("THE SHADOWS STRIKE! " + human.getName() + " lost a spirit.");
                showNativeAlert(Alert.AlertType.INFORMATION, "Shadow Trap", "A spirit stepped into darkness and returned to the void.");
            }

            Colour winner = game.checkWin();
            if (winner != null) {
                updateLog("THE SAGA ENDS. " + winner + " claims victory.");
                showNativeAlert(Alert.AlertType.INFORMATION, "Victory", "The journey is complete. " + winner + " is victorious.");
                return;
            }

            executeCPUTurns();

        } catch (GameException e) {
            showNativeAlert(Alert.AlertType.WARNING, "Forbidden Action", e.getMessage());
            game.deselectAll();
            guiSelectedMarbles.clear();
            updateUI();
        }
    }
    
    private void handleDiscardTurn() {
        Player human = game.getPlayers().get(0);
        if (human.getSelectedCard() == null) {
            showNativeAlert(Alert.AlertType.WARNING, "Nothing to Discard", "Select a card to throw into the fire.");
            return;
        }
        updateLog(human.getName() + " cast " + human.getSelectedCard().getName() + " into the flames and waited.");
        try { game.endPlayerTurn(); } catch (Exception ignored) {}
        guiSelectedMarbles.clear();
        updateUI();
        executeCPUTurns();
    }

    private void executeCPUTurns() {
        if (cpuTimeline != null && cpuTimeline.getStatus() == Timeline.Status.RUNNING) return;

        setControlsEnabled(false); 

        cpuTimeline = new Timeline();
        KeyFrame kf = new KeyFrame(Duration.seconds(1.2), e -> {
            Player human = game.getPlayers().get(0);

            if (game.getActivePlayerColour() == human.getColour()) {
                if (!game.canPlayTurn()) {
                    updateLog(human.getName() + " stood still (No Cards).");
                    try { game.endPlayerTurn(); } catch (Exception ignored) {}
                    guiSelectedMarbles.clear();
                    updateUI();
                } else {
                    setControlsEnabled(true);
                    cpuTimeline.stop();
                }
            } else {
                Player active = null;
                for (Player p : game.getPlayers()) if (p.getColour() == game.getActivePlayerColour()) active = p;
                
                if (active instanceof CPU) {
                    if (game.canPlayTurn()) {
                        try { active.play(); } catch (Exception ignored) {}
                    }
                    try { game.endPlayerTurn(); } catch (Exception ignored) {}
                    updateUI();

                    ArrayList<Card> fp = game.getFirePit();
                    String actionCard = "Shadows";
                    for (int i = fp.size() - 1; i >= 0; i--) {
                        if (fp.get(i) != null) { actionCard = fp.get(i).getName(); break; }
                    }
                    updateLog(active.getName() + " moved in silence. (Used: " + actionCard + ")");

                    Colour winner = game.checkWin();
                    if (winner != null) {
                        updateLog("THE SAGA ENDS. " + winner + " claims victory.");
                        showNativeAlert(Alert.AlertType.INFORMATION, "Victory", winner + " has claimed the realm.");
                        cpuTimeline.stop();
                    }
                }
            }
        });
        
        cpuTimeline.getKeyFrames().add(kf);
        cpuTimeline.setCycleCount(Timeline.INDEFINITE);
        cpuTimeline.play();
    }

    // --- Native Alert Wrapper ---
    private void showNativeAlert(Alert.AlertType type, String title, String content) {
        Alert alert = new Alert(type);
        alert.setTitle(title);
        alert.setHeaderText(null);
        alert.setContentText(content);
        alert.getDialogPane().getStylesheets().add(getBaseCSS());
        alert.showAndWait();
    }

    // --- Mathematical Layout Helpers ---
    private double[] getCrossCoordinates(int index) {
        int side = index / 25;
        int pos = index % 25;
        double x = 270, y = 110; 
        if(side == 0) { x += pos * CELL_SIZE; y = 110; }
        else if(side == 1) { x = 270 + 25 * CELL_SIZE; y = 110 + pos * CELL_SIZE; }
        else if(side == 2) { x = 270 + (25 - pos) * CELL_SIZE; y = 110 + 25 * CELL_SIZE; }
        else if(side == 3) { x = 270; y = 110 + (25 - pos) * CELL_SIZE; }
        return new double[]{x, y};
    }

    private double[] getSafeZoneCoords(Colour c, int idx) {
        double[] base = getCrossCoordinates(getEngineBaseOffset(c));
        return new double[]{base[0] + 30, base[1] + 30 + (idx * CELL_SIZE)}; 
    }

    private double[] getHomeZoneCoords(Colour c) {
        switch(c) {
            case RED: return new double[]{240, 130};
            case BLUE: return new double[]{810, 130};
            case GREEN: return new double[]{810, 680};
            case YELLOW: return new double[]{240, 680};
            default: return new double[]{0,0};
        }
    }

    private int getEngineBaseOffset(Colour c) {
        for(int i = 0; i < game.getBoard().getSafeZones().size(); i++) {
            if(game.getBoard().getSafeZones().get(i).getColour() == c) return i * 25;
        }
        return 0;
    }

    private Color getMutedColor(Colour c) {
        switch (c) {
            case RED: return Color.web("#B71C1C"); // Deep Vermillion
            case BLUE: return Color.web("#1A237E"); // Ink Blue
            case GREEN: return Color.web("#1B5E20"); // Pine Green
            case YELLOW: return Color.web("#F57F17"); // Darkened Gold
            default: return Color.web(YOTEI_BLACK);
        }
    }

