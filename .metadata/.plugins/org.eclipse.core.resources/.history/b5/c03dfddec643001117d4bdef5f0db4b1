    private void initializeGameEngine() {
        TextInputDialog dialog = new TextInputDialog("Wanderer");
        dialog.setTitle("Identify Thyself");
        dialog.setHeaderText(null);
        dialog.setContentText("Enter thy name:");
        dialog.getDialogPane().getStylesheets().add(getBaseCSS());

        Optional<String> result = dialog.showAndWait();
        String playerName = result.isPresent() && !result.get().trim().isEmpty() ? result.get() : "Wanderer";

        try {
            game = new Game(playerName);
        } catch (IOException e) {
            showNativeAlert(Alert.AlertType.ERROR, "Fractured Realm", "Could not decipher Cards.csv: " + e.getMessage());
            window.setScene(menuScene);
            return;
        }

        boardPane = new AnchorPane();
        addAshEffect(boardPane); // Persist atmosphere into the game

        setupGameUIComponents();
        updateUI();

        gameScene = new Scene(boardPane, 1350, 950);
        gameScene.getStylesheets().add(getBaseCSS());

        gameScene.setOnKeyPressed(e -> {
            if (e.getCode() == KeyCode.F && !controlsPane.isDisabled()) {
                try {
                    game.fieldMarble();
                    updateLog(game.getPlayers().get(0).getName() + " swiftly summoned a spirit to the field.");
                    guiSelectedMarbles.clear();
                    updateUI();
                } catch (GameException ex) {
                    showNativeAlert(Alert.AlertType.WARNING, "Path Blocked", ex.getMessage());
                }
            }
        });

        window.setScene(gameScene);
        updateLog("The journey begins. Step carefully, " + playerName + ".");
    }

