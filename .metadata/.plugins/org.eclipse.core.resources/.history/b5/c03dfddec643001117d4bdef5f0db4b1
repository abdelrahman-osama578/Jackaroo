    private void addAshEffect(AnchorPane pane) {
        Group ashGroup = new Group();
        Random rand = new Random();
        for (int i = 0; i < 60; i++) {
            Circle ash = new Circle(rand.nextDouble() * 2 + 1, Color.rgb(200, 200, 200, rand.nextDouble() * 0.5 + 0.2));
            ash.setEffect(new GaussianBlur(rand.nextDouble() * 2));
            ash.setTranslateX(rand.nextDouble() * 1350);
            ash.setTranslateY(rand.nextDouble() * 950);

            Timeline fall = new Timeline(new KeyFrame(Duration.seconds(rand.nextDouble() * 10 + 5), 
                new javafx.animation.KeyValue(ash.translateYProperty(), 1000),
                new javafx.animation.KeyValue(ash.translateXProperty(), ash.getTranslateX() - 150)
            ));
            fall.setCycleCount(Animation.INDEFINITE);
            fall.play();
            ashGroup.getChildren().add(ash);
        }
        pane.getChildren().add(0, ashGroup);
    }

