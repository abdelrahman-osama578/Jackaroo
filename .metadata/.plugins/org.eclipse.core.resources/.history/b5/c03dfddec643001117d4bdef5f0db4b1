    private void drawHumanHand() {
        Player human = game.getPlayers().get(0);
        for (Card card : human.getHand()) {
            StackPane cardPane = new StackPane();
            cardPane.setPrefSize(85, 125);
            
            Rectangle cardBg = new Rectangle(85, 125, Color.web(YOTEI_WHITE));
            cardBg.setArcWidth(8); cardBg.setArcHeight(8);
            cardBg.setStroke(Color.web(YOTEI_BLACK));
            cardBg.setStrokeWidth(1);
            
            DropShadow drop = new DropShadow(5, 0, 3, Color.rgb(0,0,0,0.3));
            cardPane.setEffect(drop);

            Label cardText = new Label();
            cardText.setFont(Font.font("Georgia", FontWeight.BOLD, 14));
            cardText.setTextFill(Color.web(YOTEI_BLACK));
            cardText.setAlignment(Pos.CENTER);
            cardText.setTextAlignment(TextAlignment.CENTER);

            if (card instanceof Standard) {
                Standard std = (Standard) card;
                String suitSym = getSuitSymbol(std.getSuit());
                cardText.setText(std.getName() + "\n\n" + suitSym);
                if (std.getSuit() == model.card.standard.Suit.HEART || std.getSuit() == model.card.standard.Suit.DIAMOND) {
                    cardText.setTextFill(Color.web(YOTEI_RED));
                }
            } else {
                cardText.setText(card.getName() + "\n\n(Wild)");
            }

            cardPane.getChildren().addAll(cardBg, cardText);

            // Hover interactions
            ScaleTransition scaleUp = new ScaleTransition(Duration.millis(150), cardPane);
            scaleUp.setToX(1.05); scaleUp.setToY(1.05);
            ScaleTransition scaleDown = new ScaleTransition(Duration.millis(150), cardPane);
            scaleDown.setToX(1.0); scaleDown.setToY(1.0);

            cardPane.setOnMouseEntered(e -> {
                cardPane.setCursor(javafx.scene.Cursor.HAND);
                scaleUp.play();
            });
            cardPane.setOnMouseExited(e -> scaleDown.play());

            cardPane.setOnMouseClicked(e -> {
                try {
                    game.selectCard(card);
                    // Reset all
                    handPane.getChildren().forEach(n -> {
                        StackPane sp = (StackPane) n;
                        ((Rectangle)sp.getChildren().get(0)).setStroke(Color.web(YOTEI_BLACK));
                        ((Rectangle)sp.getChildren().get(0)).setStrokeWidth(1);
                        sp.setTranslateY(0);
                    });
                    // Style selected
                    cardBg.setStroke(Color.web(YOTEI_RED));
                    cardBg.setStrokeWidth(3);
                    
                    TranslateTransition jump = new TranslateTransition(Duration.millis(100), cardPane);
                    jump.setToY(-10);
                    jump.play();

                } catch (GameException ex) {
                    showNativeAlert(Alert.AlertType.WARNING, "Selection Error", ex.getMessage());
                }
            });
            handPane.getChildren().add(cardPane);
        }
    }

    private String getSuitSymbol(model.card.standard.Suit suit) {
        switch(suit) {
            case HEART: return "♥";
            case DIAMOND: return "♦";
            case SPADE: return "♠";
            case CLUB: return "♣";
            default: return "";
        }
    }

    private void updateFirepit() {
        if (firepitPane.getChildren().size() > 1) {
            firepitPane.getChildren().remove(1, firepitPane.getChildren().size());
        }
        ArrayList<Card> fp = game.getFirePit();
        Card topCard = null;
        for (int i = fp.size() - 1; i >= 0; i--) {
            if (fp.get(i) != null) {
                topCard = fp.get(i);
                break;
            }
        }
        if (topCard != null) {
            StackPane topCardVis = new StackPane();
            Rectangle cardBg = new Rectangle(80, 120, Color.web(YOTEI_WHITE));
            cardBg.setStroke(Color.web(YOTEI_BLACK));
            cardBg.setStrokeWidth(1);
            
            Label cardLabel = new Label(topCard.getName());
            cardLabel.setFont(Font.font("Georgia", FontWeight.NORMAL, 12));
            cardLabel.setTextFill(Color.web(YOTEI_BLACK));
            
            topCardVis.getChildren().addAll(cardBg, cardLabel);
            topCardVis.setRotate(new Random().nextInt(10) - 5); // Slight organic rotation
            firepitPane.getChildren().add(topCardVis);
        }
    }

