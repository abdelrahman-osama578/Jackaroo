    private void updateUI() {
        boardPane.getChildren().removeIf(node -> node instanceof Circle || node.getId() != null);
        handPane.getChildren().clear();

        drawTrackAndMarbles();
        drawPlayerInfoAndCPUHands();
        drawHumanHand();
        updateFirepit();

        turnLabel.setText("ACTIVE: " + game.getActivePlayerColour());
        nextPlayerLabel.setText("Awaiting: " + game.getNextPlayerColour());
    }

    private void setControlsEnabled(boolean enabled) {
        handPane.setDisable(!enabled);
        controlsPane.setDisable(!enabled);
    }

    private void drawTrackAndMarbles() {
        ArrayList<Cell> track = game.getBoard().getTrack();
        for (int i = 0; i < track.size(); i++) {
            Cell cell = track.get(i);
            double[] coords = getCrossCoordinates(i);
            
            Rectangle rect = new Rectangle(coords[0], coords[1], CELL_SIZE, CELL_SIZE);
            rect.setStroke(Color.web(YOTEI_BLACK, 0.4));
            rect.setStrokeWidth(1.2);
            rect.setStrokeType(StrokeType.INSIDE);
            
            // Minimalist muted cell coloring
            if (cell.getCellType() == CellType.BASE) rect.setFill(Color.rgb(200, 200, 200, 0.7));
            else if (cell.getCellType() == CellType.ENTRY) rect.setFill(Color.rgb(220, 220, 220, 0.5));
            else if (cell.isTrap()) rect.setFill(Color.rgb(17, 17, 17, 0.8));
            else rect.setFill(Color.rgb(255, 255, 255, 0.3));
            
            rect.setId("trackCell");
            boardPane.getChildren().add(rect);

            if (cell.getMarble() != null) drawMarble(cell.getMarble(), coords[0], coords[1]);
        }

        for (SafeZone zone : game.getBoard().getSafeZones()) {
            int idx = 0;
            for(Cell cell : zone.getCells()) {
                double[] coords = getSafeZoneCoords(zone.getColour(), idx++);
                Rectangle sr = new Rectangle(coords[0], coords[1], CELL_SIZE, CELL_SIZE);
                sr.setStroke(getMutedColor(zone.getColour()));
                sr.setStrokeWidth(1.5);
                sr.setFill(getMutedColor(zone.getColour()).deriveColor(1,1,1,0.15));
                sr.setId("safeCell");
                boardPane.getChildren().add(sr);
                
                if(cell.getMarble() != null) drawMarble(cell.getMarble(), coords[0], coords[1]);
            }
        }

        for (Player p : game.getPlayers()) {
            double[] homeBase = getHomeZoneCoords(p.getColour());
            int count = 0;
            for (Marble m : p.getMarbles()) {
                drawMarble(m, homeBase[0] + (count % 2) * 28, homeBase[1] + (count / 2) * 28);
                count++;
            }
        }
    }

    private void drawMarble(Marble marble, double x, double y) {
        Circle circle = new Circle(x + CELL_SIZE / 2.0, y + CELL_SIZE / 2.0, CELL_SIZE / 2.4);
        
        // 3D Stone Go-piece effect
        RadialGradient grad = new RadialGradient(0, 0, 0.3, 0.3, 1, true, CycleMethod.NO_CYCLE, 
            new Stop(0, Color.WHITE), new Stop(1, getMutedColor(marble.getColour())));
        circle.setFill(grad);
        circle.setStroke(Color.web(YOTEI_BLACK));
        circle.setStrokeWidth(0.5);
        
        DropShadow shadow = new DropShadow(4, 2, 2, Color.rgb(0,0,0,0.4));
        circle.setEffect(shadow);

        circle.setOnMouseEntered(e -> circle.setCursor(javafx.scene.Cursor.HAND));
        
        circle.setOnMouseClicked(e -> {
            if(controlsPane.isDisabled()) return; 
            try {
                game.selectMarble(marble);
                guiSelectedMarbles.add(marble); 
                
                // Selection vermillion glow
                DropShadow glow = new DropShadow(15, Color.web(YOTEI_RED));
                circle.setEffect(glow);
                circle.setStroke(Color.web(YOTEI_RED));
                circle.setStrokeWidth(2);
            } catch (GameException ex) {
                showNativeAlert(Alert.AlertType.WARNING, "Invalid Selection", ex.getMessage());
            }
        });
        boardPane.getChildren().add(circle);
    }

    private void drawPlayerInfoAndCPUHands() {
        for (Player p : game.getPlayers()) {
            double[] coords = getHomeZoneCoords(p.getColour());
            Label nameLabel = new Label(p.getName() + "\nSouls: " + p.getHand().size());
            nameLabel.setFont(Font.font("Georgia", FontWeight.NORMAL, 14));
